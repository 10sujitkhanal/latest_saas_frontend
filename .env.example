# Tenant-facing SaaS app -- env template.
# Copy to ``.env.local`` for dev or ``.env.production.local`` for prod;
# both are gitignored. ``.env.production`` (which IS gitignored too)
# holds the morefungi.com host wiring for production builds.

# Dev: backend on http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Dev only: backend port for the same-host fallback (default 8000).
NEXT_PUBLIC_BACKEND_PORT=8000

# Per-tenant API routing (used in production):
#   On <tenant>.morefungi.com the app calls <tenant>.api.morefungi.com
# Leave the API_APEX blank in dev -- the resolver falls back to
# NEXT_PUBLIC_API_BASE_URL above.
NEXT_PUBLIC_FRONTEND_APEX=
NEXT_PUBLIC_API_APEX=

# Agency portal links (used by the landing/signup CTAs).
#   Dev:  http://agency.localhost:3001
#   Prod: https://agency.morefungi.com
NEXT_PUBLIC_AGENCY_PORTAL_URL=http://agency.localhost:3001
NEXT_PUBLIC_AGENCY_SIGNUP_URL=http://agency.localhost:3001/auth/signup
